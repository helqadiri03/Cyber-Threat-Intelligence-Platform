# Copy to .env and adjust before: docker compose up -d

MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme
# Host port for mongosh from your machine (default 27018 avoids conflict with local mongod on 27017)
MONGO_HOST_PORT=27018

# URL the browser uses to reach the FastAPI backend
VITE_API_URL=http://localhost:8000

# Database names (used by setup scripts and backend)
CASSANDRA_KEYSPACE=cyber_threats
MONGODB_DATABASE=cyber_intelligence
MONGODB_URI=mongodb://admin:changeme@localhost:27018/?authSource=admin
CASSANDRA_HOSTS=localhost
REDIS_URL=redis://localhost:6379/0
REDIS_HOST_PORT=6380

# Phase 3 — Kafka producer (cyber_events_raw)
KAFKA_TOPIC=cyber_events_raw
PRODUCER_SLEEP_SECONDS=0.05
PRODUCER_LOOP=true
PRODUCER_BATCH_SIZE=500
PRODUCER_MAX_ROWS=0
